# AI Provider: "auto" (default), "ollama", "lmstudio", or "anthropic" (paid)
AI_PROVIDER=auto

# Anthropic API (paid) - get key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LM Studio (free/local) - download from https://lmstudio.ai, load a model, enable local server
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=

# Ollama (free/local) - install from https://ollama.com, then: ollama pull llama3.2:3b
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# -------------------------------------------------------------------------
# External data sources for batch property enrichment (Sprint 6+)
# All sources are free, public, and require no API keys:
#   - FEMA National Flood Hazard Layer (ArcGIS REST)
#   - Cal Fire Fire Hazard Severity Zones (ArcGIS REST)
#   - OpenStreetMap Overpass API — amenity counts for walkability
# Fetched by app.py directly. No environment variables needed.
# -------------------------------------------------------------------------
